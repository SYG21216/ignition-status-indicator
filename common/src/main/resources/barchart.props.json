{
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "series": {
            "type": "array",
            "description": "Array of data series.",
            "default": [
                {
                    "name": "Series A",
                    "color": "#6366f1",
                    "data": [42, 68, 35, 78, 55, 90, 47]
                }
            ],
            "items": {
                "type": "object",
                "properties": {
                    "name":  { "type": "string" },
                    "color": { "type": "string", "format": "color" },
                    "data":  { "type": "array", "items": { "type": "number" } }
                }
            }
        },
        "labels": {
            "type": "array",
            "description": "Category labels for the bars.",
            "default": ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"],
            "items": { "type": "string" }
        },
        "title": {
            "type": "string",
            "default": "Bar Chart",
            "description": "Chart title."
        },
        "orientation": {
            "type": "string",
            "enum": ["vertical", "horizontal"],
            "default": "vertical",
            "description": "Bar direction."
        },
        "stacked": {
            "type": "boolean",
            "default": false,
            "description": "Stack multiple series on top of each other."
        },
        "showValues": {
            "type": "boolean",
            "default": false,
            "description": "Display the numeric value on top of each bar."
        },
        "showGrid": {
            "type": "boolean",
            "default": true,
            "description": "Show background grid lines."
        },
        "showLegend": {
            "type": "boolean",
            "default": true,
            "description": "Show the series legend."
        },
        "barRadius": {
            "type": "integer",
            "default": 4,
            "minimum": 0,
            "maximum": 20,
            "description": "Corner radius of each bar in pixels."
        },
        "backgroundColor": {
            "type": "string",
            "format": "color",
            "default": "#ffffff",
            "description": "Chart background color."
        },
        "style": {
            "$ref": "urn:ignition-schema:schemas/style-properties.schema.json",
            "default": { "classes": "" }
        }
    }
}
