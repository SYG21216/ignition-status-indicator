{
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "title": {
            "type": "string",
            "default": "Bar Chart Panel",
            "description": "Panel title."
        },
        "series": {
            "type": "array",
            "description": "Data series. Each series has name, color, data array. Each data point: { label, v, extraProps }",
            "default": [
                {
                    "name": "Series A",
                    "color": "#73bf69",
                    "data": [
                        { "label": "Jan", "v": 30 },
                        { "label": "Feb", "v": 45 },
                        { "label": "Mar", "v": 28 },
                        { "label": "Apr", "v": 55 },
                        { "label": "May", "v": 40 }
                    ]
                }
            ],
            "items": {
                "type": "object",
                "properties": {
                    "name":  { "type": "string" },
                    "color": { "type": "string", "format": "color" },
                    "data":  {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "label": { "type": "string" },
                                "v":     { "type": "number" },
                                "extraProps": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "name":  { "type": "string" },
                                            "value": { "type": "string" }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "orientation": {
            "type": "string",
            "enum": ["vertical", "horizontal"],
            "default": "vertical",
            "description": "Bar direction: 'vertical' (default) or 'horizontal'."
        },
        "stacked": {
            "type": "boolean",
            "default": false,
            "description": "Stack bars on top of each other (requires same labels across series)."
        },
        "barRadius": {
            "type": "integer",
            "default": 3,
            "minimum": 0,
            "maximum": 20,
            "description": "Corner radius of bars."
        },
        "showValues": {
            "type": "boolean",
            "default": false,
            "description": "Show numeric value above/inside each bar."
        },
        "backgroundColor": {
            "type": "string",
            "format": "color",
            "default": "#181b1f",
            "description": "Panel background color."
        },
        "style": {
            "$ref": "urn:ignition-schema:schemas/style-properties.schema.json",
            "default": { "classes": "" }
        }
    }
}
