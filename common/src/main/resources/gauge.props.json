{
    "type": "object",
    "additionalProperties": false,
    "required": ["value"],
    "properties": {
        "value": {
            "type": "number",
            "default": 0,
            "description": "Current value to display on the gauge."
        },
        "min": {
            "type": "number",
            "default": 0,
            "description": "Minimum value of the gauge range."
        },
        "max": {
            "type": "number",
            "default": 100,
            "description": "Maximum value of the gauge range."
        },
        "unit": {
            "type": "string",
            "default": "%",
            "description": "Unit label displayed next to the value."
        },
        "title": {
            "type": "string",
            "default": "Gauge",
            "description": "Title label displayed at the top."
        },
        "thresholds": {
            "type": "array",
            "description": "Color thresholds. Each entry has a 'value' and 'color'. Sorted ascending.",
            "default": [
                { "value": 0,  "color": "#73bf69" },
                { "value": 60, "color": "#f2cc0c" },
                { "value": 80, "color": "#f2495c" }
            ],
            "items": {
                "type": "object",
                "properties": {
                    "value": { "type": "number" },
                    "color": { "type": "string", "format": "color" }
                }
            }
        },
        "showValue": {
            "type": "boolean",
            "default": true,
            "description": "Show the numeric value in the center of the gauge."
        },
        "decimalPlaces": {
            "type": "integer",
            "default": 1,
            "minimum": 0,
            "maximum": 6,
            "description": "Number of decimal places for the displayed value."
        },
        "arcWidth": {
            "type": "integer",
            "default": 18,
            "minimum": 4,
            "maximum": 60,
            "description": "Thickness of the gauge arc in SVG units."
        },
        "startAngle": {
            "type": "number",
            "default": -120,
            "description": "Start angle of the arc in degrees (0=top, -90=left, 90=right)."
        },
        "endAngle": {
            "type": "number",
            "default": 120,
            "description": "End angle of the arc in degrees."
        },
        "needleStyle": {
            "type": "string",
            "enum": ["none", "line", "arrow"],
            "default": "none",
            "description": "Pointer/needle style drawn on the gauge."
        },
        "valueFontSize": {
            "type": "integer",
            "default": 18,
            "minimum": 8,
            "maximum": 48,
            "description": "Font size for the center value text (SVG units)."
        },
        "backgroundColor": {
            "type": "string",
            "format": "color",
            "default": "#181b1f",
            "description": "Gauge background color."
        },
        "style": {
            "$ref": "urn:ignition-schema:schemas/style-properties.schema.json",
            "default": { "classes": "" }
        }
    }
}
